rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Login-free personal sync: every device reads/writes one shared space
    // whose id is a hard-to-guess secret baked into the app, plus everything
    // nested under it (the photos subcollection lives at
    // userData/{space}/photos/{hash}). The {document=**} wildcard extends the
    // rule down into that subcollection. Only that exact space is reachable,
    // so knowing the project id alone is not enough — keep the link private.
    match /userData/{space}/{document=**} {
      allow read, write: if space == "46c68c32b4b569bc4d608302bea012e6271070ce";
    }
  }
}
