rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Each user can only read/write their own document AND everything
    // nested under it (the photos subcollection lives at
    // userData/{uid}/photos/{hash}). The {document=**} wildcard is what
    // extends the per-user rule down into that subcollection.
    match /userData/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
