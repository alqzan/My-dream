rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Login-free personal sync — same shared secret space id as Firestore.
    // Media lives at userData/{space}/photos/{hash} and .../audios/{hash}.
    // Only that exact space is reachable, so knowing the project alone is not
    // enough. Uploads are capped and must be an image or audio; deletes
    // (request.resource == null) are allowed within the space.
    //
    // The placeholder below is intentionally not the real space id — these
    // rules are informational only. The rules actually enforced in production
    // are edited and published from the Firebase Console directly, never from
    // this repo, so the real secret never touches version control.
    match /userData/{space}/{allPaths=**} {
      allow read: if space == "REPLACED_IN_FIREBASE_CONSOLE";
      allow write: if space == "REPLACED_IN_FIREBASE_CONSOLE"
        && (request.resource == null
            || (request.resource.size < 25 * 1024 * 1024
                && request.resource.contentType.matches('(image|audio)/.*')));
    }
  }
}
